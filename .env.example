# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://jobclub:changeme@localhost:5432/jobclub"
POSTGRES_PASSWORD="changeme"

# ============================================
# Authentication (NextAuth.js)
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://thejobclub.com.au"

# ============================================
# Stripe Payment Processing
# ============================================
# Find these in Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Webhook signing secret from Stripe Dashboard > Developers > Webhooks
# Set endpoint to: https://thejobclub.com.au/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price ID for the monthly subscription product
# Product: "Job Club by MLF" — $39.99 AUD/month
STRIPE_PRICE_ID="price_1THJiOAX1FfAZ93bJZ1xqz7D"

# Price ID for the yearly subscription
# Product: "Job Club by MLF" — $400 AUD/year
# Find this in Stripe Dashboard > Products > Job Club by MLF > Pricing (second row)
STRIPE_PRICE_ID_YEARLY="price_1THJljAX1FfAZ93b21AR4jYe"

# ============================================
# Email (Resend API)
# ============================================
# API key from https://resend.com
RESEND_API_KEY="re_..."
EMAIL_FROM="Job Club <noreply@thejobclub.com.au>"

# ============================================
# Sentry Error Monitoring
# ============================================
# Get your DSN from: Sentry Dashboard > Settings > Projects > Client Keys (DSN)
# The DSN is public/safe — it just identifies where to send error events
NEXT_PUBLIC_SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"
SENTRY_DSN="https://xxx@yyy.ingest.sentry.io/zzz"

# Auth token for source map uploads during build (from Sentry > Settings > Auth Tokens)
# Needs Project (Read & Write) + Release (Admin) scopes
SENTRY_AUTH_TOKEN="sntrys_..."

# ============================================
# PostHog Product Analytics
# ============================================
# Get your project API key from: PostHog Dashboard > Settings > Project API Key
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ============================================
# Application Environment
# ============================================
NODE_ENV="production"
