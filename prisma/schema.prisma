generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  role                 String    @default("user")
  stripeCustomerId     String?
  subscriptionStatus   String    @default("inactive")
  subscriptionId       String?
  currentPeriodEnd     DateTime?
  preferredStates      String?   // Comma-separated state codes e.g. "QLD,NSW"
  preferredCategories  String?   // Comma-separated categories e.g. "Agriculture,Construction"
  emailAlerts          Boolean   @default(true)
  only88Days           Boolean   @default(false) // Only notify about 88-day eligible jobs
  preferredLanguage    String    @default("fr") // "fr" or "en"
  onboardingCompleted  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  savedJobs            SavedJob[]
  notifications        Notification[]
}

model Job {
  id          String    @id @default(cuid())
  title       String
  company     String
  state       String
  location    String
  category    String
  type        String    @default("casual")
  pay         String?
  description String
  applyUrl    String?
  sourceUrl   String?
  active      Boolean   @default(true)
  eligible88Days Boolean @default(false)
  eligibilityData Json?  // Deterministic verdict snapshot from JobCandidate at approval time:
                         // { eligibility_88_days, eligibility_reason, eligibility_confidence,
                         //   industry, postcode, award_id, award_min_hourly,
                         //   award_min_casual_hourly, pay_parsed_hourly, pay_kind, pay_status,
                         //   pay_gap, pay_gap_pct }
                         // Frozen at approve time — not auto-refreshed when reference data changes
                         // (run scripts/reassess-eligibility.js if needed).
  expiresAt   DateTime? // Auto-set to 30 days after creation if not specified
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  savedBy     SavedJob[]
  @@index([active, expiresAt])
  @@index([eligible88Days])
  @@index([active, expiresAt, state, category])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  @@unique([userId, jobId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("new_job") // new_job
  title     String
  message   String
  jobId     String?
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, read])
  @@index([userId, createdAt])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model JobCandidate {
  id              String    @id @default(cuid())
  source          String
  sourceUrl       String
  sourceJobId     String?
  rawData         Json
  dedupeHash      String
  status          String    @default("pending") // pending | approved | rejected | duplicate | auto_rejected
  rejectReason    String?
  classifierScore Json?
  promotedJobId   String?
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?

  @@index([status, createdAt])
  @@index([dedupeHash])
  @@index([source, createdAt])
  @@unique([source, sourceJobId])
}

model JobSource {
  id            String    @id @default(cuid())
  slug          String    @unique
  label         String
  category      String    // government | aggregator | ats_rss | competitor | manual | direct
  sheetTab      String?   // organizational grouping from Lucas's source sheet: seek | gumtree | facebook | packhouse | station | website | mine_agency | job_agency | government | manual
  // How data is ingested — drives the 3-button dashboard (rapide / intelligent / manuel):
  //   structured_api  → ATS APIs (Greenhouse, Workable, Workday) — Flow A (~$0/listing)
  //   structured_html → custom-selector HTML scrapers (BPJB, gov SPAs)  — Flow A
  //   generic_web     → generic_career_page (Playwright + Claude)        — Flow B (~$0.01-0.05/listing)
  //   extension       → browser-extension territory (FB groups, anti-bot sites) — Flow C
  //   keyword_search  → search-keyword inventory (Seek/Gumtree prompts)  — Flow C
  //   manual          → manual entry / catch-all
  ingestionStrategy String?
  enabled       Boolean   @default(true)
  adapter       String?   // adapter name for the source runner (workforce_australia | harvest_trail | generic_career_page | manual | extension)
  config        Json?     // adapter-specific config (search URL, default state/category, selectors for generic adapter, etc.)
  lastRunAt     DateTime?
  lastRunStatus String?   // ok | error | skipped
  lastRunError  String?
  totalSeen     Int       @default(0)
  totalApproved Int       @default(0)
  totalRejected Int       @default(0)
  createdAt     DateTime  @default(now())
}

model SourcingRun {
  id                  String    @id @default(cuid())
  status              String    @default("pending") // pending | running | completed | failed
  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  // Slugs of JobSources scoped to this run. Empty array = "all enabled".
  sourceSlugs         Json      // string[]
  totalSources        Int       @default(0)
  processedSources    Int       @default(0)
  // Aggregate counters across all sources in the run.
  totalListingsFound  Int       @default(0)
  totalListingsNew    Int       @default(0)
  totalImported       Int       @default(0)
  totalDuplicates     Int       @default(0)
  totalErrors         Int       @default(0)
  // Per-source detail: array of { slug, status, listingsFound, listingsNew, imported, duplicates, errors, errorMessage?, durationMs }
  perSourceResults    Json?
  errorMessage        String?
  triggeredBy         String?   // admin user id/email

  @@index([status, startedAt])
}
